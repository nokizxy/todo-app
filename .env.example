# Local mode is the safe default. Set this to true after Supabase is configured.
REACT_APP_ENABLE_CLOUD_SYNC=false
REACT_APP_FOCUSFLOW_USER_ID=demo-user

# Vercel Serverless API environment variables.
# Do not commit real keys. Add them in Vercel Project Settings instead.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
